  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=snapaccount;Username=postgres;Password=#{DB_PASSWORD}#;Search Path=auth"
  },
  "AllowedOrigins": {
    "AdminPanel": "http://localhost:5173",
    "Mobile": "http://localhost:3000"
  },
  "GCP": {
    "ProjectId": ""
  },
  "Firebase": {
    "ServiceAccountJson": ""
  },
  "GCS": {
    "DocumentsBucket": "snapaccount-documents"
  },
  "Razorpay": {
    "WebhookSecret": ""
  },
  "PanEncryption": {
    "Key": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
  },
  "Kyc": {
    "Provider": "mock",
    "BaseUrl": "https://api.sandbox.co.in",
    "ApiVersion": "1.0",
    "TimeoutSeconds": 30,
    "VerificationTokenTtlMinutes": 15,
    "Consent": "Y",
