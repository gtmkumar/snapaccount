{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": {
    "AdminPanel": "http://localhost:3000",
    "Mobile": "http://localhost:3000"
  },
  "Firebase": {
    "ServiceAccountJson": ""
  },
  "Resilience": {
    "Http": {
      "IGstnApiClient": {
        "AttemptTimeoutSeconds": 30,
        "TotalTimeoutSeconds": 60
      },
      "IIrpClient": {
        "AttemptTimeoutSeconds": 30,
        "TotalTimeoutSeconds": 60
      },
      "IEwbClient": {
        "AttemptTimeoutSeconds": 30,
        "TotalTimeoutSeconds": 60
      },
      "IImsGstnClient": {
        "AttemptTimeoutSeconds": 30,
        "TotalTimeoutSeconds": 60
      },
      "IOcrServiceResolver": {
        "AttemptTimeoutSeconds": 60,
        "TotalTimeoutSeconds": 90,
        "MaxConcurrency": 20,
        "MaxQueuedRequests": 20
      }
    },
    "Dependency": {
      "firebase-auth": {
        "AttemptTimeoutSeconds": 5,
        "MaxConcurrency": 100,
        "MaxQueuedRequests": 100
      },
      "gcs": {
        "AttemptTimeoutSeconds": 30
      },
      "pubsub": {
        "AttemptTimeoutSeconds": 10
      }
    }
  }
}
