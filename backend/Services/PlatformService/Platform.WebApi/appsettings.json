{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": {
    "AdminPanel": "http://localhost:3000",
    "Mobile": "http://localhost:3000"
  },
  "Firebase": {
    "ServiceAccountJson": ""
  },
  "Auth": {
    "Otp": {
      "ValidityMinutes": 5,
      "MaxAttempts": 3,
      "CooldownMinutes": 30
    },
    "Session": {
      "TokenLifetimeHours": 12,
      "RefreshTokenLifetimeDays": 30
    }
  }
}
