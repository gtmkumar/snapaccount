# SnapAccount — Local Development Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── PostgreSQL ────────────────────────────────
POSTGRES_PASSWORD=postgresql

# ── Redis ─────────────────────────────────────
# REDIS_PASSWORD: used by docker-compose to set the Redis container password.
REDIS_PASSWORD=redispassword
# REDIS_CONNECTION_STRING: StackExchange.Redis connection string used by ChatService
#   for the SignalR backplane (Microsoft.AspNetCore.SignalR.StackExchangeRedis) and
#   ephemeral state (typing indicators with 30s TTL).
#   Local dev: connect to the Docker Compose redis container (no auth required locally).
#   Staging/production: value comes from GCP Secret Manager (redis-connection-string-staging
#   or redis-connection-string-prod) — set automatically by infra/setup.sh Step 6.
#   Format: <host>:<port>,abortConnect=false,connectTimeout=5000,syncTimeout=5000
REDIS_CONNECTION_STRING=redis:6379,abortConnect=false,connectTimeout=5000,syncTimeout=5000

# ── Firebase ──────────────────────────────────
# Download from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}   # paste JSON inline or use a path
FIREBASE_WEB_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_WEB_APP_ID=1:123456789:web:abc123

# ── JWT ───────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-64-char-string-before-use

# ── GCP (for Document AI, Storage, Vertex AI) ─
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-bucket-name
DOCUMENT_AI_PROCESSOR_ID=your-processor-id
VERTEX_AI_LOCATION=asia-south1
VERTEX_AI_MODEL=gemini-1.5-pro

# ── Messaging (Phase 6E — NotificationService) ──
# MSG91: obtain API key at https://msg91.com
# DLT registration required for Indian transactional SMS — takes 2-3 business days.
# GCP Secret Manager name: msg91-api-key
MSG91_API_KEY=your-msg91-api-key
# MSG91 DLT sender ID: the 6-char sender ID approved on TRAI DLT portal (e.g. SNPACC).
# GCP Secret Manager name: msg91-sender-id
MSG91_SENDER_ID=SNPACC
# SendGrid: obtain at https://app.sendgrid.com → Settings → API Keys
# SPF/DKIM domain authentication requires DNS changes — coordinate with team lead.
# GCP Secret Manager name: sendgrid-api-key
SENDGRID_API_KEY=SG.your-sendgrid-api-key
# Firebase Admin SDK JSON for FCM push dispatch (NotificationService).
# Download from Firebase Console → Project Settings → Service Accounts → Generate new private key.
# GCP Secret Manager name: firebase-admin-json
# For local dev: paste single-line JSON or set GOOGLE_APPLICATION_CREDENTIALS to file path.
FIREBASE_ADMIN_JSON={"type":"service_account","project_id":"your-project",...}

# ── Payments ──────────────────────────────────
# Leave blank during development — Subscription Service handles missing keys gracefully
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── AI ────────────────────────────────────────
SARVAM_AI_API_KEY=your-sarvam-key

# ── Government APIs ───────────────────────────
# Leave blank during development — services use mock adapters when keys are absent.

# Legacy GST portal credentials (kept for backward compat — superceded by GSTN_* below in Phase 6B)
GST_PORTAL_URL=https://api.gst.gov.in
GST_PORTAL_CLIENT_ID=
NIC_EINVOICE_URL=https://einvoice1.gst.gov.in

# ── Phase 6B: GSTN Sandbox / Production credentials ─────────────────────────
# GSTN API (Goods and Services Tax Network)
# Apply for sandbox access at: https://developer.gst.gov.in/
# IMPORTANT: Sandbox onboarding requires a valid GSTIN and takes 5-10 business days.
# A signed agreement with GSTN is required before production access is granted.
# See P6-FLAG-04 in .claude/orchestrator/ for current status.
# GCP Secret Manager names: gstn-client-id, gstn-client-secret
GSTN_CLIENT_ID=
GSTN_CLIENT_SECRET=

# IRP — Invoice Registration Portal (e-invoicing, mandatory for B2B turnover > 5 Cr)
# Apply at: https://einvoice1.gst.gov.in → API Access
# GCP Secret Manager names: irp-client-id, irp-client-secret
IRP_CLIENT_ID=
IRP_CLIENT_SECRET=

# EWB — e-Way Bill portal
# Apply at: https://ewaybillgst.gov.in → API Registration
# GCP Secret Manager names: ewb-client-id, ewb-client-secret
EWB_CLIENT_ID=
EWB_CLIENT_SECRET=

# GST production API feature flag (controls mock vs live adapter in GstService)
# Set to "true" only after GSTN sandbox credentials verified and prod agreement signed.
# In production this is read from Secret Manager: feature-flag-gst-production-apis-enabled
# For local dev: set to "false" to use mock adapters (default and recommended during dev)
GST_PRODUCTION_APIS_ENABLED=false

# IT Portal (Income Tax e-filing)
IT_PORTAL_URL=https://efileapi.incometax.gov.in

# ── Phase 6C: Loan Hub ────────────────────────
# GCS bucket for loan application packages (sanction letters, executed agreements,
# disbursement advices). In production, value comes from Secret Manager: gcs-loan-packages-bucket
# For local dev: leave blank or point at a fake-gcs-server bucket.
LOAN_PACKAGE_BUCKET_NAME=

# Partner bank webhook shared secret template (per-bank format).
# In production, operators create per-bank secrets in Secret Manager:
#   partner-bank-webhook-secret-icici
#   partner-bank-webhook-secret-hdfc
# These are NOT mounted as env vars — LoanService reads them via Secret Manager API at runtime.
# This placeholder documents the expected format of each per-bank secret value.
# GCP Secret Manager template secret name: partner-bank-webhook-secret-template
# For local dev: set a dummy value; webhook signature validation is skipped when empty.
PARTNER_BANK_WEBHOOK_SECRET_TEMPLATE=

# ── Frontend ──────────────────────────────────
VITE_API_BASE_URL=http://localhost:5001
