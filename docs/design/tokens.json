    "text": {
      "_meta": {
        "since": "2.1.0",
        "source": "design-elevation-spec.md §1.3 + accessibility-standard.md §4 (binding)",
        "rule": "neutral-400 is text.disabled ONLY. No screen may use neutral-400 for meaningful text. Each light/dark value is validated ≥4.5:1 on its intended surface (text.primary/secondary/tertiary), per a11y §4."
      },
      "primary": {
        "light": "#0F172A",
        "dark": "#F8FAFC",
        "description": "Headings, primary body. light=neutral-900 on light surface, dark=neutral-50 on dark surface"
      },
      "secondary": {
        "light": "#475569",
        "dark": "#94A3B8",
        "description": "Secondary body, meaningful captions (≥4.5:1). light=neutral-600, dark=neutral-400"
      },
      "tertiary": {
        "light": "#64748B",
        "dark": "#94A3B8",
        "description": "Least-emphasis meaningful text, ≥4.5:1 on its surface. light=neutral-500 (4.76:1 on white). a11y override of design-elevation-spec §1.3: dark lifts to neutral-400 #94A3B8 — neutral-500 #64748B only reaches 3.75:1 on dark canvas / 3.07:1 on dark raised and FAILS the 4.5:1 gate. There is no slate shade that keeps tertiary darker than secondary AND ≥4.5:1 on dark surfaces, so in dark mode tertiary collapses onto secondary's value (#94A3B8); separate tertiary from secondary by weight/size, not colour, in dark mode. (Spec authorizes this: where elevation spec and a11y spec conflict, a11y wins.)"
      },
      "disabled": {
        "light": "#94A3B8",
        "dark": "#475569",
        "description": "Disabled only — never for meaningful text. light=neutral-400, dark=neutral-600"
      },
      "onBrand": {
        "light": "#FFFFFF",
        "dark": "#FFFFFF",
        "description": "Text on brand/coloured fills"
      }
    }
