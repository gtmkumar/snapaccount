<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>
    <IsPackable>false</IsPackable>
    <RootNamespace>LoanService.IntegrationTests</RootNamespace>
  </PropertyGroup>

  <!--
    NOTE FOR BACKEND-AGENT (P6-INT-02):
    Before these tests can be run, add the following to
    backend/Services/FinanceService/Finance.WebApi/Finance.WebApi.csproj:

      <ItemGroup>
        <InternalsVisibleTo Include="LoanService.IntegrationTests" />
      </ItemGroup>

    Without this, the implicit Program class generated by top-level statements
    is internal and not accessible to WebApplicationFactory<Program>.
    This follows the same pattern as AuthService.IntegrationTests,
    CallbackService.IntegrationTests, and GstService.IntegrationTests.

    Additionally, the DisbursementWebhookHandler integration tests require
    ICredentialEncryptionService to be mockable in the test DI container.
  -->

  <ItemGroup>
    <PackageReference Include="xunit" Version="2.*" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.*">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="FluentAssertions" Version="6.*" />
    <PackageReference Include="Moq" Version="4.*" />
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" Version="10.*" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.*" />
    <PackageReference Include="Testcontainers.PostgreSql" Version="3.*" />
    <PackageReference Include="coverlet.collector" Version="6.*">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\backend/Services/FinanceService/Finance.WebApi/Finance.WebApi.csproj" />
    <ProjectReference Include="..\..\..\backend/Services/FinanceService/Finance.Application/Finance.Application.csproj" />
    <ProjectReference Include="..\..\..\backend/Services/FinanceService/Finance.Domain/Finance.Domain.csproj" />
    <ProjectReference Include="..\..\..\backend/Services/FinanceService/Finance.Infrastructure/Finance.Infrastructure.csproj" />
    <ProjectReference Include="..\..\..\backend\Shared\SnapAccount.Shared.Domain\SnapAccount.Shared.Domain.csproj" />
  </ItemGroup>

</Project>
