{
  "name": "snapaccount",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|i18next|react-i18next)"
    ],
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "moduleNameMapper": {
      "^react-native/Libraries/BatchedBridge/NativeModules$": "<rootDir>/src/__mocks__/nativeModules.js",
      "^expo/src/async-require/messageSocket$": "<rootDir>/src/__mocks__/expoMessageSocket.js",
      "^@expo/vector-icons$": "<rootDir>/src/__mocks__/vectorIcons.js",
      "^@expo/vector-icons/(.*)$": "<rootDir>/src/__mocks__/vectorIcons.js",
      "^@react-native-async-storage/async-storage$": "<rootDir>/src/__mocks__/asyncStorage.ts",
      "^expo-secure-store$": "<rootDir>/src/__mocks__/secureStore.ts",
      "^@react-native-firebase/(.*)$": "<rootDir>/src/__mocks__/firebase.ts",
      "^@react-native-community/netinfo$": "<rootDir>/src/__mocks__/netinfo.ts",
      "^expo-device$": "<rootDir>/src/__mocks__/expoDevice.ts",
      "^expo-notifications$": "<rootDir>/src/__mocks__/expoNotifications.ts",
      "^expo-haptics$": "<rootDir>/src/__mocks__/expoHaptics.ts",
      "^@microsoft/signalr$": "<rootDir>/src/__mocks__/signalr.ts",
      "^expo-task-manager$": "<rootDir>/src/__mocks__/expoTaskManager.ts",
      "^expo-background-fetch$": "<rootDir>/src/__mocks__/expoBackgroundFetch.ts",
      "^expo-store-review$": "<rootDir>/src/__mocks__/expoStoreReview.ts",
      "^expo-screen-capture$": "<rootDir>/src/__mocks__/expoScreenCapture.ts",
      "^expo-constants$": "<rootDir>/src/__mocks__/expoConstants.ts",
      "^expo-local-authentication$": "<rootDir>/src/__mocks__/expoLocalAuthentication.ts"
    }
  },
  "dependencies": {
    "@expo/vector-icons": "~14.0.4",
    "@hookform/resolvers": "^3.3.4",
    "@microsoft/signalr": "^10.0.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-firebase/app": "^20.0.0",
    "@react-native-firebase/auth": "^20.0.0",
    "@react-native-firebase/crashlytics": "^24.0.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@react-navigation/stack": "^6.3.20",
    "@tanstack/react-query": "^5.17.0",
    "axios": "^1.6.5",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-background-fetch": "~13.0.6",
    "expo-camera": "~16.0.18",
    "expo-constants": "~17.0.0",
    "expo-device": "~7.0.3",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.1",
    "expo-image-picker": "~16.0.6",
    "expo-linear-gradient": "~14.0.2",
    "expo-linking": "~7.0.5",
    "expo-local-authentication": "~15.0.2",
    "expo-media-library": "~17.0.6",
    "expo-network": "~7.0.5",
    "expo-notifications": "~0.29.0",
    "expo-screen-capture": "~7.0.1",
    "expo-secure-store": "~14.0.1",
    "expo-status-bar": "~2.0.0",
    "expo-store-review": "~8.0.1",
    "expo-task-manager": "~12.0.6",
    "i18next": "^26.0.8",
    "nativewind": "^4.0.1",
    "react": "18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.49.3",
    "react-i18next": "^17.0.4",
    "react-native": "0.76.9",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-gifted-charts": "^1.4.0",
    "react-native-otp-verify": "^1.1.7",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-ssl-pinning": "^1.0.17",
    "react-native-svg": "15.8.0",
    "react-native-web": "^0.19.13",
    "tailwindcss": "^3.4.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.3.12",
    "@types/react-native": "~0.73.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^52.0.6",
    "typescript": "~5.3.3"
  },
  "private": true
}
