{
  "name": "snapaccount",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|i18next|react-i18next)"
    ],
    "setupFiles": [
      "<rootDir>/src/__mocks__/setup.js"
    ],
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect",
      "<rootDir>/src/__mocks__/jestAfterEnv.setup.js"
    ],
    "moduleNameMapper": {
      "^react-native/Libraries/BatchedBridge/NativeModules$": "<rootDir>/src/__mocks__/nativeModules.js",
      "^react-native/Libraries/NativeModules/specs/NativeSourceCode$": "<rootDir>/src/__mocks__/nativeSourceCode.js",
      "^react-native/src/private/specs_DEPRECATED/modules/NativeSourceCode$": "<rootDir>/src/__mocks__/nativeSourceCode.js",
      "^expo/virtual/streams$": "<rootDir>/src/__mocks__/expoVirtualStreams.js",
      "^expo/src/winter$": "<rootDir>/src/__mocks__/expoWinter.js",
      "^expo/src/winter/(.*)$": "<rootDir>/src/__mocks__/expoWinter.js",
      "^expo/src/async-require/messageSocket$": "<rootDir>/src/__mocks__/expoMessageSocket.js",
      "^@tanstack/react-query$": "<rootDir>/src/__mocks__/reactQueryTracked.js",
      "^tanstack-react-query-actual$": "<rootDir>/node_modules/@tanstack/react-query",
      "^@expo/vector-icons$": "<rootDir>/src/__mocks__/vectorIcons.js",
      "^@expo/vector-icons/(.*)$": "<rootDir>/src/__mocks__/vectorIcons.js",
      "^@react-native-async-storage/async-storage$": "<rootDir>/src/__mocks__/asyncStorage.ts",
      "^expo-secure-store$": "<rootDir>/src/__mocks__/secureStore.ts",
      "^@react-native-firebase/(.*)$": "<rootDir>/src/__mocks__/firebase.ts",
      "^@react-native-community/netinfo$": "<rootDir>/src/__mocks__/netinfo.ts",
      "^expo-device$": "<rootDir>/src/__mocks__/expoDevice.ts",
      "^expo-notifications$": "<rootDir>/src/__mocks__/expoNotifications.ts",
      "^expo-haptics$": "<rootDir>/src/__mocks__/expoHaptics.ts",
      "^expo-crypto$": "<rootDir>/src/__mocks__/expoCrypto.ts",
      "^@microsoft/signalr$": "<rootDir>/src/__mocks__/signalr.ts",
      "^expo-task-manager$": "<rootDir>/src/__mocks__/expoTaskManager.ts",
      "^expo-background-fetch$": "<rootDir>/src/__mocks__/expoBackgroundFetch.ts",
      "^expo-store-review$": "<rootDir>/src/__mocks__/expoStoreReview.ts",
      "^expo-screen-capture$": "<rootDir>/src/__mocks__/expoScreenCapture.ts",
      "^expo-constants$": "<rootDir>/src/__mocks__/expoConstants.ts",
      "^expo-local-authentication$": "<rootDir>/src/__mocks__/expoLocalAuthentication.ts",
      "^react-native-safe-area-context$": "<rootDir>/src/__mocks__/reactNativeSafeAreaContext.js",
      "^react-native/src/private/featureflags/specs/NativeReactNativeFeatureFlags$": "<rootDir>/src/__mocks__/nativeFeatureFlags.js",
      "^react-native/src/private/featureflags/ReactNativeFeatureFlagsBase$": "<rootDir>/src/__mocks__/nativeFeatureFlags.js",
      "^react-native/src/private/featureflags/ReactNativeFeatureFlags$": "<rootDir>/src/__mocks__/nativeFeatureFlags.js",
      "^nativewind/jsx-runtime$": "react/jsx-runtime"
    },
    "resolver": "react-native-worklets/jest/resolver.js"
  },
  "dependencies": {
    "@expo/config-plugins": "^56.0.8",
    "@expo/vector-icons": "^15.0.2",
    "@hookform/resolvers": "^3.3.4",
    "@microsoft/signalr": "^10.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@react-navigation/stack": "^6.3.20",
    "@tanstack/react-query": "^5.17.0",
    "axios": "^1.6.5",
    "expo": "~56.0.0",
    "expo-apple-authentication": "~56.0.4",
    "expo-asset": "~56.0.15",
    "expo-auth-session": "~56.0.13",
    "expo-background-fetch": "~56.0.16",
    "expo-camera": "~56.0.7",
    "expo-constants": "~56.0.16",
    "expo-crypto": "~56.0.4",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image-picker": "~56.0.15",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-local-authentication": "~56.0.4",
    "expo-media-library": "~56.0.6",
    "expo-network": "~56.0.4",
    "expo-notifications": "~56.0.15",
    "expo-screen-capture": "~56.0.4",
    "expo-secure-store": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-store-review": "~56.0.3",
    "expo-task-manager": "~56.0.16",
    "expo-web-browser": "~56.0.5",
    "i18next": "^26.0.8",
    "nativewind": "^4.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.49.3",
    "react-i18next": "^17.0.4",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3",
    "tailwindcss": "^3.4.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.14",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~56.0.4",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.4",
    "typescript": "~6.0.3"
  },
  "private": true
}
