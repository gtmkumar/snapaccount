# SnapAccount Mobile Environment Variables
# Copy this to .env.local and fill in values
# NEVER commit actual credentials to source control

# API
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000/api

# Firebase — values from google-services.json / GoogleService-Info.plist
# These are loaded automatically via @react-native-firebase/app
# Do NOT add Firebase config here — use google-services.json

# Environment
EXPO_PUBLIC_ENV=development
