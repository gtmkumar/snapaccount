{
  "expo": {
    "name": "SnapAccount",
    "slug": "snapaccount",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E40AF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.snapaccount.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "SnapAccount uses the camera to photograph bills and documents for OCR processing.",
        "NSPhotoLibraryUsageDescription": "SnapAccount needs access to your photo library to upload documents.",
        "NSPhotoLibraryAddUsageDescription": "SnapAccount saves downloaded reports to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      },
      "package": "com.snapaccount.app",
      "permissions": [
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "SnapAccount uses the camera to photograph bills and documents."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SnapAccount accesses your photos to upload documents.",
          "cameraPermission": "SnapAccount uses the camera to capture documents."
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2563EB"
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-status-bar",
      "expo-web-browser",
      "expo-apple-authentication"
    ],
    "scheme": "snapaccount",
    "extra": {
      "eas": {
        "projectId": "snapaccount-app"
      },
      "apiBaseUrl": "http://localhost:5000",
      "integrityCloudProjectNumber": "",
      "msg91OtpAppHash": "",
      "firebase": {
        "apiKey": "AIzaSyBQ1xgWAWRIXPFKwcM3yR6GZEfW99G53L4",
        "authDomain": "snap-account.firebaseapp.com",
        "projectId": "snap-account",
        "storageBucket": "snap-account.firebasestorage.app",
        "messagingSenderId": "754356628614",
        "appId": "1:754356628614:web:0884cef123784cb9a0f507",
        "measurementId": "G-155RG9L0PJ"
      },
      "googleAuth": {
        "iosClientId": "",
        "androidClientId": "",
        "webClientId": "754356628614-hu7lqvm3uq7lp1chirpsq5ncpd6286tf.apps.googleusercontent.com"
      }
    }
  }
}
